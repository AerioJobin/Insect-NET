<script>
// Gallery data injected server-side — no extra HTTP request needed
const GALLERY_DATA = <?php echo json_encode($galleryGroups); ?>;
const TOTAL_IMAGES = <?php echo (int)$totalImages; ?>;

let allImages = [];
GALLERY_DATA.forEach(g => g.files.forEach(f => allImages.push(f)));

const gallery      = document.getElementById('imageGallery');
const galleryCount = document.getElementById('galleryCount');

// ── Build gallery DOM ─────────────────────────────────────────
function buildGallery() {
    gallery.innerHTML = '';
    if (TOTAL_IMAGES === 0) {
        gallery.innerHTML = '<div class="gallery-empty">No images found for this device.</div>';
        return;
    }
    GALLERY_DATA.forEach(group => {
        if (group.date) {
            const h = document.createElement('div');
            h.className = 'date-heading';
            h.textContent = group.date;
            gallery.appendChild(h);
        }
        group.files.forEach(item => {
            const card = document.createElement('div');
            card.className = 'image-container';
            card.dataset.filename = item.name;

            const wrapper = document.createElement('div');
            wrapper.className = 'img-wrapper';

            const img = document.createElement('img');
            img.dataset.src = item.src;  // lazy — not loaded yet
            img.alt = item.name;
            img.addEventListener('load',  () => { img.classList.add('loaded'); wrapper.classList.add('img-ready'); });
            img.addEventListener('error', () => { wrapper.classList.add('img-ready'); img.style.display='none'; });
            img.addEventListener('click', () => openLightbox(item.src));
            wrapper.appendChild(img);
            card.appendChild(wrapper);

            const delBtn = document.createElement('button');
            delBtn.className = 'delete-btn';
            delBtn.title = 'Delete';
            delBtn.textContent = '×';
            delBtn.addEventListener('click', e => { e.stopPropagation(); deleteImage(item.name, card); });
            card.appendChild(delBtn);

            const fname = document.createElement('p');
            fname.className = 'img-filename';
            fname.textContent = item.name;
            card.appendChild(fname);

            gallery.appendChild(card);
        });
    });
    initLazyLoad();
}

// ── IntersectionObserver lazy load ────────────────────────────
function initLazyLoad() {
    const imgs = gallery.querySelectorAll('img[data-src]');
    if (!imgs.length) return;
    if ('IntersectionObserver' in window) {
        const obs = new IntersectionObserver((entries, o) => {
            entries.forEach(en => {
                if (en.isIntersecting) {
                    const img = en.target;
                    img.src = img.dataset.src;
                    delete img.dataset.src;
                    o.unobserve(img);
                }
            });
        }, { rootMargin:'200px' });
        imgs.forEach(img => obs.observe(img));
    } else {
        imgs.forEach(img => { img.src = img.dataset.src; }); // fallback
    }
}

buildGallery();

// ── Delete — POSTs back to THIS file with action=delete ───────
function deleteImage(filename, cardEl) {
    if (!confirm(`Delete "${filename}"?`)) return;
    cardEl.classList.add('deleting');

    fetch('index.php', {
        method:  'POST',
        headers: {'Content-Type':'application/x-www-form-urlencoded'},
        body:    `action=delete&file=${encodeURIComponent(filename)}`
    })
    .then(r => r.json())
    .then(data => {
        if (data.status === 'ok') {
            cardEl.style.transition = 'opacity 0.3s,transform 0.3s';
            cardEl.style.opacity    = '0';
            cardEl.style.transform  = 'scale(0.95)';
            setTimeout(() => {
                cardEl.remove();
                allImages = allImages.filter(i => i.name !== filename);
                const rem = gallery.querySelectorAll('.image-container').length;
                if (galleryCount) galleryCount.textContent = `${rem} image${rem!==1?'s':''}`;
                // Remove any date headings that now have no cards under them
                gallery.querySelectorAll('.date-heading').forEach(h => {
                    const next = h.nextElementSibling;
                    if (!next || next.classList.contains('date-heading')) h.remove();
                });
                if (rem === 0) gallery.innerHTML = '<div class="gallery-empty">No images found for this device.</div>';
            }, 300);
        } else {
            cardEl.classList.remove('deleting');
            alert('Delete failed: ' + (data.message || 'Unknown error'));
        }
    })
    .catch(() => {
        cardEl.classList.remove('deleting');
        alert('Network error — delete failed.');
    });
}

// ── Lightbox ──────────────────────────────────────────────────
const lightbox      = document.getElementById('lightbox');
const lightboxImg   = document.getElementById('lightboxImg');
const lightboxCap   = document.getElementById('lightboxCap');
const lightboxClose = document.getElementById('lightboxClose');
const lightboxPrev  = document.getElementById('lightboxPrev');
const lightboxNext  = document.getElementById('lightboxNext');
let   currentIndex  = -1;

function openLightbox(src) {
    currentIndex = allImages.findIndex(i => i.src === src);
    showAt(currentIndex);
    lightbox.classList.add('open');
    lightbox.setAttribute('aria-hidden','false');
}
function showAt(idx) {
    if (!allImages.length) return;
    currentIndex = (idx + allImages.length) % allImages.length;
    lightboxImg.src = allImages[currentIndex].src;
    lightboxCap.textContent = allImages[currentIndex].name;
}
function closeLightbox() {
    lightbox.classList.remove('open');
    lightbox.setAttribute('aria-hidden','true');
    lightboxImg.src = '';
}
lightbox.addEventListener('click',      e => { if (e.target===lightbox) closeLightbox(); });
lightboxClose.addEventListener('click', e => { e.stopPropagation(); closeLightbox(); });
lightboxPrev.addEventListener('click',  e => { e.stopPropagation(); showAt(currentIndex-1); });
lightboxNext.addEventListener('click',  e => { e.stopPropagation(); showAt(currentIndex+1); });
document.addEventListener('keydown', e => {
    if (!lightbox.classList.contains('open')) return;
    if (e.key==='ArrowRight') showAt(currentIndex+1);
    if (e.key==='ArrowLeft')  showAt(currentIndex-1);
    if (e.key==='Escape')     closeLightbox();
});

// ── Device map + live status polling ─────────────────────────
const DEVICE_ID    = "<?php echo addslashes($camId); ?>";
const DEV_DEFAULTS = { cam1:{lat:13.0187,lng:77.5708}, cam2:{lat:13.0127,lng:77.5677} };
const base         = DEV_DEFAULTS[DEVICE_ID] || {lat:13.0127,lng:77.5677};

const devMap    = L.map('map').setView([base.lat,base.lng], 15);
L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(devMap);
const devMarker = L.marker([base.lat,base.lng]).addTo(devMap);

function timeSince(ts) {
    const d = Math.floor(Date.now()/1000) - ts;
    if (d < 60)    return 'Just now';
    if (d < 3600)  return `${Math.floor(d/60)} min ago`;
    if (d < 86400) return `${Math.floor(d/3600)} hr ago`;
    return `${Math.floor(d/86400)} days ago`;
}

function fetchStatus() {
    fetch(`get_status.php?device_id=${DEVICE_ID}`)
        .then(r => r.json())
        .then(data => {
            const $ = id => document.getElementById(id);
            if (data.status === 'success' && data.latest) {
                const d  = data.latest;
                const ts = d.timestamp ? parseInt(d.timestamp) : null;
                const v  = parseFloat(d.battery_voltage);
                $('waveshareStatusFill').style.width = '100%';
                $('waveshareStatusText').textContent  = 'Link Active';
                if (!isNaN(v)) $('deviceBattery').textContent = `Battery: ${v.toFixed(2)}V`;
                if (ts)        $('deviceLastSeen').textContent = `Last seen: ${timeSince(ts)}`;
                const lat = parseFloat(d.gps_latitude);
                const lng = parseFloat(d.gps_longitude);
                if (!isNaN(lat) && !isNaN(lng)) {
                    devMarker.setLatLng([lat,lng]);
                    devMap.setView([lat,lng]);
                    $('deviceGPS').textContent = `${lat.toFixed(5)}, ${lng.toFixed(5)}`;
                }
            } else {
                $('waveshareStatusFill').style.width = '0%';
                $('waveshareStatusText').textContent  = 'No Signal';
            }
            $('deviceLastUpdated').textContent = `Last updated: ${new Date().toLocaleTimeString()}`;
        })
        .catch(() => {
            document.getElementById('deviceLastUpdated').textContent =
                `Last updated: ${new Date().toLocaleTimeString()} (fetch failed)`;
        });
}
setInterval(fetchStatus, 5000);
fetchStatus();
</script>

<?php endif; ?>
</body>
</html>
