<script>
const DEVICES      = ['cam1','cam2'];
const DEFAULT_LOCS = { cam1:{lat:13.0187,lng:77.5708}, cam2:{lat:13.0127,lng:77.5677} };
const DEV_LABELS   = { cam1:'INMT Device 1', cam2:'INMT Device 2' };

const fleetMap     = L.map('map').setView([DEFAULT_LOCS.cam1.lat, DEFAULT_LOCS.cam1.lng], 13);
L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(fleetMap);
const fleetMarkers = {};

function timeSince(ts) {
    const d = Math.floor(Date.now()/1000) - ts;
    if (d < 60)    return 'Just now';
    if (d < 3600)  return `${Math.floor(d/60)} min ago`;
    if (d < 86400) return `${Math.floor(d/3600)} hr ago`;
    return `${Math.floor(d/86400)} days ago`;
}

function setMarker(id, lat, lng, battLabel, statusLabel, statusColor) {
    const name = DEV_LABELS[id] || id;
    const link = `index.php?view=dashboard&device=${id.replace('cam','device')}`;
    const popup = `<div style="text-align:center;font-family:Inter,sans-serif;min-width:140px;">
        <strong style="color:#8A2245;">${name}</strong><br>
        <span style="color:${statusColor};font-weight:bold;">● ${statusLabel}</span><br>
        <small>Batt: ${battLabel}</small><br><br>
        <a href="${link}" style="background:#8A2245;color:white;padding:4px 10px;border-radius:4px;text-decoration:none;font-size:11px;">VIEW DASHBOARD</a>
    </div>`;
    if (!fleetMarkers[id]) {
        fleetMarkers[id] = L.marker([lat,lng]).addTo(fleetMap);
        fleetMarkers[id].bindTooltip(name, {direction:'top',offset:[0,-10]});
        fleetMarkers[id].on('mouseover', () => fleetMarkers[id].openTooltip());
        fleetMarkers[id].on('mouseout',  () => fleetMarkers[id].closeTooltip());
        fleetMarkers[id].bindPopup(popup);
        fleetMarkers[id].on('click', () => { window.location.href = link; });
    } else {
        fleetMarkers[id].setLatLng([lat,lng]);
        fleetMarkers[id].setPopupContent(popup);
    }
}

function updateFleet() {
    document.getElementById('fleetLastUpdated').textContent = `Last updated: ${new Date().toLocaleTimeString()}`;
    DEVICES.forEach(id => {
        fetch(`get_status.php?device_id=${id}`)
            .then(r => r.json())
            .then(data => {
                const def = DEFAULT_LOCS[id];
                if (data.status === 'success' && data.latest) {
                    const d   = data.latest;
                    const v   = parseFloat(d.battery_voltage);
                    const ts  = d.timestamp ? parseInt(d.timestamp) : null;
                    let lat   = parseFloat(d.gps_latitude);
                    let lng   = parseFloat(d.gps_longitude);
                    if (isNaN(lat)||isNaN(lng)) { lat=def.lat; lng=def.lng; }

                    const battEl = document.getElementById(`battery-${id}`);
                    const seenEl = document.getElementById(`lastseen-${id}`);
                    const statEl = document.getElementById(`status-${id}`);
                    if (battEl) battEl.textContent = isNaN(v) ? '--' : `${v.toFixed(2)}V`;
                    if (ts && seenEl) seenEl.textContent = timeSince(ts);

                    const diff = ts ? (Date.now()/1000 - ts) : Infinity;
                    if (statEl) {
                        if      (diff < 300)  { statEl.textContent='Online';  statEl.className='device-status online'; }
                        else if (diff < 3600) { statEl.textContent='Stale';   statEl.className='device-status stale'; }
                        else                  { statEl.textContent='Offline'; statEl.className='device-status offline'; }
                    }
                    const bL = isNaN(v)?'--':`${v.toFixed(2)}V`;
                    const sL = diff<300?'Online':diff<3600?'Stale':'Offline';
                    const sC = diff<300?'#16a34a':diff<3600?'#92400e':'#ef4444';
                    setMarker(id, lat, lng, bL, sL, sC);
                } else {
                    setMarker(id, def.lat, def.lng, '--', 'Offline', '#ef4444');
                }
            })
            .catch(() => {
                const def = DEFAULT_LOCS[id];
                setMarker(id, def.lat, def.lng, '--', 'Offline', '#ef4444');
            });
    });
}
setInterval(updateFleet, 5000);
updateFleet();
</script>

