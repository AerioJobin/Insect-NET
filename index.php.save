        <div id="map"></div>
        <div class="status-bar">
            <div class="status-label">Waveshare Board</div>
            <div class="status-track">
                <div id="waveshareStatusFill" class="status-fill"></div>
            </div>
            <div id="waveshareStatusText" class="status-text">Awaiting signal...</div>
        </div>
    </div>

    <h3 style="margin-bottom:16px;">Captured Images</h3>
    <div class="image-gallery">
        <?php
        $files = glob($upload_dir . "*.{jpg,png,jpeg}", GLOB_BRACE);
        usort($files, function($a, $b) { return filemtime($b) - filemtime($a); });
        $camId = str_replace('device', 'cam', $device);
        $deviceFiles = array_filter($files, function($f) use ($camId) {
            return strpos(basename($f), $camId) !== false;
        });

        if (empty($deviceFiles)): ?>
            <div style="grid-column: 1/-1; text-align: center; padding: 60px 20px; border: 2px dashed var(--border); border-radius: 12px; color: var(--text-dim);">
                <div style="font-size: 3em; margin-bottom: 12px;">📷</div>
                <p style="font-family:'Space Mono',monospace; font-size:0.9em; letter-spacing:2px;">NO IMAGES CAPTURED YET</p>
                <p style="font-size:0.8em; margin-top:8px;">Images will appear here once <?php echo strtoupper($camId); ?> starts uploading.</p>
            </div>
        <?php else:
            foreach ($deviceFiles as $file) {
                $base = basename($file);
                echo "<div class='image-container' data-file='$base'>";
                echo "  <button class='delete-btn' type='button' aria-label='Delete image' data-file='$base'>&times;</button>";
                echo "  <a class='image-link' href='$file' target='_blank' rel='noopener'>";
                echo "    <img src='$file' alt='$base'>";
                echo "  </a>";
                echo "  <p>$base</p>";
                echo "</div>";
            }
        endif; ?>
    </div>
</div>

<script>
    const deviceId = "<?php echo str_replace('device', 'cam', $device); ?>";
    const defaultLocation = {
        cam1: { lat: 13.0187, lng: 77.5708 },
        cam2: { lat: 13.0127, lng: 77.5677 }
    };
    const baseLoc = defaultLocation[deviceId] || { lat: 13.0127, lng: 77.5677 };

    let deviceMap = L.map('map').setView([baseLoc.lat, baseLoc.lng], 15);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(deviceMap);
    let marker = L.marker([baseLoc.lat, baseLoc.lng]).addTo(deviceMap);

    function updateStatusBar(stateText, fillPercent) {
        const fill = document.getElementById('waveshareStatusFill');
        const text = document.getElementById('waveshareStatusText');
        if (!fill || !text) return;
        const pct = Math.max(0, Math.min(fillPercent, 100));
        fill.style.width = pct + '%';
        text.textContent = stateText;
        text.style.color = pct > 0 ? "var(--text)" : "var(--text-dim)";
    }

    function fetchStatus() {
        fetch(`get_status.php?device_id=${deviceId}`)
            .then(r => r.json())
            .then(data => {
                if (data.status === 'success' && data.latest) {
                    updateStatusBar('Link active', 65);

                    const lat = parseFloat(data.latest.gps_latitude);
                    const lng = parseFloat(data.latest.gps_longitude);
                    if (!isNaN(lat) && !isNaN(lng)) {
                        marker.setLatLng([lat, lng]);
                        deviceMap.setView([lat, lng]);
                    }
                } else {
                    updateStatusBar('Awaiting data', 0);
                }
            })
            .catch(() => {
                updateStatusBar('Offline', 0);
                marker.setLatLng([baseLoc.lat, baseLoc.lng]);
                deviceMap.setView([baseLoc.lat, baseLoc.lng]);
            });
    }

    function bindDeleteButtons() {
        const deleteUrl = new URL('delete_image.php', window.location.href).toString();
        document.querySelectorAll('.delete-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                const file = btn.dataset.file;
                if (!file) return;
                if (!confirm(`Delete ${file}?`)) return;

                const body = new URLSearchParams();
                body.append('file', file);

                fetch(deleteUrl, {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: body.toString()
                })
                .then(async r => {
                    const text = await r.text();
                    let res = {};
                    try { res = text ? JSON.parse(text) : {}; }
                    catch (err) { throw new Error(text || `Server error (${r.status})`); }
                    if (!r.ok) {
                        throw new Error(res.message || `Server error (${r.status})`);
                    }
                    return res;
                })
                .then(res => {
                    if (res.status === 'ok') {
                        const card = btn.closest('.image-container');
                        if (card) card.remove();
                        if (!document.querySelector('.image-container')) {
                            // if all images removed, refresh to show empty state
                            location.reload();
                        }
                    } else {
                        throw new Error(res.message || 'Could not delete image.');
                    }
                })
                .catch((err) => alert(err.message || 'Delete failed. Please try again.'));
            });
        });
    }

    setInterval(fetchStatus, 5000);
    fetchStatus();
    bindDeleteButtons();
</script>
<?php endif; ?>
</body>
</html>
