    <style>
        :root {
            --primary:   #8A2245;
            --secondary: #6b1a36;
            --accent:    #c44569;
            --bg:        #FDFBF7;
            --surface:   #FFFFFF;
            --border:    #dee2e6;
            --text:      #4E4247;
            --text-dim:  #6c757d;
            --shadow:    rgba(0, 0, 0, 0.1);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            line-height: 1.6;
        }

        .brand-card {
            display: flex;
            align-items: center;
            gap: 22px;
            padding: 20px 28px;
            background: linear-gradient(135deg, #fff, #f7f2f4);
            border: 1px solid var(--border);
            border-radius: 16px;
            box-shadow: 0 10px 28px var(--shadow);
        }
        .brand-divider {
            width: 1px;
            align-self: stretch;
            background: linear-gradient(180deg, transparent, rgba(0,0,0,0.08), transparent);
        }
        .brand-logo {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .container { max-width: 1600px; margin: 0 auto; padding: 20px; }

        .header {
            background: linear-gradient(135deg, #FFFFFF 0%, #f8f0f2 100%);
            border: 1px solid var(--border);
            padding: 30px;
            border-radius: 16px;
            margin-bottom: 30px;
            box-shadow: 0 8px 32px var(--shadow);
        }

        .header-content {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 20px;
        }

        .header h1 {
            font-family: 'Space Mono', monospace;
            font-size: 2.5em;
            color: var(--accent);
            letter-spacing: 4px;
        }

        /* ── Waveshare Status Bar ── */
        .status-bar {
            display: flex;
            align-items: center;
            gap: 14px;
            background: var(--surface);
            border: 1px solid var(--border);
            padding: 16px 18px;
            border-radius: 12px;
            box-shadow: 0 6px 18px var(--shadow);
            margin-bottom: 22px;
        }
        .status-label {
            font-family: 'Space Mono', monospace;
            letter-spacing: 2px;
            font-size: 0.9em;
            color: var(--text-dim);
            text-transform: uppercase;
            white-space: nowrap;
        }
        .status-track {
            flex: 1;
            height: 10px;
            background: #f1f3f5;
            border-radius: 999px;
            overflow: hidden;
            position: relative;
        }
        .status-fill {
            position: absolute;
            inset: 0;
            width: 0%;
            background: linear-gradient(90deg, var(--primary), var(--accent));
            transition: width 0.4s ease;
        }
        .status-text {
            font-size: 0.9em;
            color: var(--text);
            font-weight: 600;
            min-width: 120px;
            text-align: right;
        }

        /* ── Layout Grids ── */
        .device-grid, .image-gallery {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
        }
        .device-card, .image-container {
            background: var(--surface);
            border: 1px solid var(--border);
            padding: 20px;
            border-radius: 12px;
            transition: 0.3s;
        }
        .device-card:hover { transform: translateY(-5px); border-color: var(--primary); cursor: pointer; }
        .image-container { position: relative; }
        .image-link { display: block; }
        .image-container img { width: 100%; border-radius: 8px; margin-bottom: 10px; }
        .delete-btn {
            position: absolute;
            top: 10px;
            right: 10px;
            border: none;
            background: rgba(0,0,0,0.6);
            color: #fff;
            border-radius: 50%;
            width: 32px;
            height: 32px;
            cursor: pointer;
            display: grid;
            place-items: center;
            font-size: 1.1em;
            line-height: 1;
            transition: background 0.2s ease;
        }
        .delete-btn:hover { background: rgba(0,0,0,0.8); }

        .device-status {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.75em;
            margin-top: 10px;
            font-weight: bold;
        }
        .online  { background: #dcfce7; color: #16a34a; }
        .offline { background: #fee2e2; color: #ef4444; }

        .back-btn {
            display: inline-block;
            margin-bottom: 20px;
            text-decoration: none;
            color: var(--primary);
            font-weight: bold;
        }
        #map {
            height: 320px;
            border-radius: 12px;
            margin-bottom: 24px;
            border: 1px solid var(--border);
        }

        /* ── Layout helpers ── */
        .panel-row {
            display: grid;
            grid-template-columns: minmax(0, 2fr) minmax(260px, 1fr);
            gap: 16px;
            align-items: stretch;
            margin-bottom: 24px;
        }
        .panel-row .status-bar { margin-bottom: 0; }

        @media (max-width: 900px) {
            .panel-row {
                grid-template-columns: 1fr;
            }
            .panel-row .status-bar { order: -1; }
        }
    </style>
</head>
<body>

