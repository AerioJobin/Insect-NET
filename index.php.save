        <div class="device-card" onclick="location.href='index.php?view=dashboard&device=device1'">
            <h3>INMT Device 1</h3>
            <p id="battery-cam1">Battery: --</p>
            <p id="location-cam1">Location: --</p>
            <div id="status-cam1" class="device-status offline">Checking...</div>
        </div>
        <div class="device-card" onclick="location.href='index.php?view=dashboard&device=device2'">
            <h3>INMT Device 2</h3>
            <p id="battery-cam2">Battery: --</p>
            <p id="location-cam2">Location: --</p>
            <div id="status-cam2" class="device-status offline">Checking...</div>
        </div>
    </div>

    <div class="header" style="margin-top:30px;">
        <h3>Fleet Map</h3>
        <div id="map"></div>
    </div>
</div>

<script>
    const devices = ['cam1', 'cam2'];
    const defaultLocations = {
        cam1: { lat: 13.0187, lng: 77.5708 }, // user-specified default
        cam2: { lat: 13.0127, lng: 77.5677 }
    };

    let map = L.map('map').setView([defaultLocations.cam1.lat, defaultLocations.cam1.lng], 13);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
    let markers = {};

    function deviceUrlFromCam(camId) {
        return `index.php?view=dashboard&device=${camId.replace('cam', 'device')}`;
    }

    function upsertMarker(camId, lat, lng) {
        const label = camId.toUpperCase();
        if (!markers[camId]) {
            markers[camId] = L.marker([lat, lng]).addTo(map);
            markers[camId].bindPopup(`<strong>${label}</strong><br><a href="${deviceUrlFromCam(camId)}">Open dashboard</a>`);
            markers[camId].on('click', () => {
                window.location.href = deviceUrlFromCam(camId);
            });
        } else {
            markers[camId].setLatLng([lat, lng]);
        }
    }

    function setOffline(id) {
        const st = document.getElementById(`status-${id}`);
        st.textContent = 'Offline';
        st.className = 'device-status offline';

        const def = defaultLocations[id];
        if (def) {
            document.getElementById(`location-${id}`).textContent = `Loc: ${def.lat}, ${def.lng}`;
            upsertMarker(id, def.lat, def.lng);
        }
    }

    function updateFleet() {
        devices.forEach(id => {
            fetch(`get_status.php?device_id=${id}`)
                .then(r => r.json())
                .then(data => {
                    if (data.status === 'success' && data.latest) {
                        const v = parseFloat(data.latest.battery_voltage);
                        const p = Math.min(100, Math.max(0, ((v - 3.0) / 1.2) * 100));
                        document.getElementById(`battery-${id}`).textContent =
                            `Battery: ${v.toFixed(2)}V (${Math.round(p)}%)`;

                        const st = document.getElementById(`status-${id}`);
                        st.textContent = 'Online';
                        st.className = 'device-status online';

                        const lat = data.latest.gps_latitude;
                        const lng = data.latest.gps_longitude;
                        document.getElementById(`location-${id}`).textContent = `Loc: ${lat}, ${lng}`;

                        upsertMarker(id, lat, lng);
                    } else {
                        setOffline(id);
                    }
                })
                .catch(() => setOffline(id));
        });
    }
    setInterval(updateFleet, 5000);
    updateFleet();
</script>

<?php elseif ($view == 'dashboard' && $device): ?>
<div class="container">
